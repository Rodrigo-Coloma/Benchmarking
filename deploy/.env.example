# ============================================================================
# deploy/.env — variables del contenedor api (y worker).
# Copia este archivo a deploy/.env y rellena los valores. NO se commitea.
# Permisos recomendados: chmod 600 deploy/.env
# ============================================================================

# Servidor
NODE_ENV=production
LOG_LEVEL=info
PORT=8080
BASE_PATH=/evidencias

# DB
# POSTGRES_PASSWORD debe coincidir con el contenido de deploy/secrets/postgres_password.txt
POSTGRES_PASSWORD=please-change-me
# DATABASE_URL lo construye docker-compose con ${POSTGRES_PASSWORD},
# no hace falta repetirlo aquí salvo que ejecutes scripts fuera de compose.

# Sesiones / argon2 — generar con: openssl rand -base64 48
SESSION_SECRET=please-change-me-with-openssl-rand
ARGON2_SECRET=please-change-me-with-openssl-rand
COOKIE_NAME=assetmgr.sid
COOKIE_DOMAIN=rcoloma.dev

# Anthropic (descubridor de schema KPIs y agentes futuros)
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings RAG, futuro)
# OPENAI_API_KEY=sk-...

# RAG service (futuro)
# RAG_URL=http://rag:8000

# Jobs
JOB_CONCURRENCY_GATHER=3
JOB_CONCURRENCY_VALIDATE=6

# Storage temporal de uploads
STORAGE_DIR=/tmp/uploads

# Email (opcional)
EMAIL_PROVIDER=none
EMAIL_FROM=evidencias@rcoloma.dev
# RESEND_API_KEY=re_...
