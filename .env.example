# =============================================================================
# Asset Manager — .env.example
# Copia este archivo a `.env` y rellena los valores. NO comitees el .env.
# =============================================================================

# --- Servidor HTTP ---
PORT=8080
BASE_PATH=/
NODE_ENV=development
LOG_LEVEL=info

# --- Postgres ---
# En dev local: asegúrate de tener un Postgres 16+ accesible.
DATABASE_URL=postgres://assetmanager:assetmanager@localhost:5432/assetmanager

# --- Sesiones y crypto ---
# En desarrollo se permiten los placeholders `dev-only-*`, pero en prod ambos
# deben ser strings aleatorios de ≥32 caracteres.
SESSION_SECRET=dev-only-insecure-session-secret-change-me
ARGON2_SECRET=dev-only-insecure-argon2-secret-change-me
COOKIE_NAME=assetmgr.sid
# COOKIE_DOMAIN=rcoloma.dev    # sólo en prod

# --- Jobs (pg-boss) ---
JOB_CONCURRENCY_GATHER=3
JOB_CONCURRENCY_VALIDATE=6
ROLE=both                       # api | worker | both

# --- LLM / RAG (opcional en PR1, requerido en PR3+) ---
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# RAG_URL=http://localhost:8000

# --- Storage ---
STORAGE_DIR=/tmp/uploads

# --- Email (opcional) ---
EMAIL_PROVIDER=none             # none | resend | sendgrid
EMAIL_FROM=noreply@local
# RESEND_API_KEY=re_...
# SENDGRID_API_KEY=SG...

# --- Dev: proxy del frontend al backend ---
VITE_API_PROXY=http://localhost:8080
